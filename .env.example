APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=avatar_bot
POSTGRES_USER=avatar_bot
POSTGRES_PASSWORD=avatar_bot

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

TELEGRAM_BOT_TOKEN=change_me

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000
CORS_ALLOW_ORIGINS=*

SUPPORT_TELEGRAM_USERNAME=your_support_username

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_WORKER_CONCURRENCY=1

STORAGE_PROVIDER=local

CLOUDFLARE_R2_ACCOUNT_ID=change_me
CLOUDFLARE_R2_ACCESS_KEY_ID=change_me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=change_me
CLOUDFLARE_R2_BUCKET=change_me
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_PRESIGNED_URL_TTL_SECONDS=86400
CLOUDFLARE_R2_PUBLIC_BASE_URL=

CRYPTOMUS_MERCHANT_ID=change_me
CRYPTOMUS_API_KEY=change_me
CRYPTOMUS_WEBHOOK_SECRET=change_me

RUNPOD_API_KEY=change_me
RUNPOD_TEMPLATE_ID=change_me
RUNPOD_GPU_TYPE=RTX 4090
RUNPOD_IDLE_TIMEOUT_SECONDS=600
RUNPOD_MAX_ACTIVE_PODS=1

GENERATION_MODE=mock
COMFYUI_PORT=8188
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_WORKFLOW_PATH=/app/workflows/infinite_talk_api.json
COMFYUI_TIMEOUT_SECONDS=7200
COMFYUI_POLL_INTERVAL_SECONDS=5
COMFYUI_TRANSIENT_RETRY_MAX_ATTEMPTS=5
COMFYUI_TRANSIENT_RETRY_BACKOFF_SECONDS=5
COMFYUI_TRANSIENT_RETRY_BACKOFF_MAX_SECONDS=30
COMFYUI_INPUT_SUBFOLDER=ultronlab
COMFYUI_OUTPUT_SUBFOLDER=InfiniteTalk

PRICING_PRICE_PER_SECOND_USD=0.012
PRICING_MIN_JOB_PRICE_USD=0.30
GENERATION_FPS=25
GENERATION_MAX_SEGMENT_SECONDS=30
SEGMENT_IMAGE_STRATEGY=last_frame
RESULT_RETENTION_HOURS=48

LOCAL_STORAGE_DIR=/app/storage
MAX_IMAGE_SIZE_MB=20
MAX_AUDIO_SIZE_MB=100
GENERATION_MAX_AUDIO_SECONDS=1800
DEBUG_ADMIN_TELEGRAM_IDS=
